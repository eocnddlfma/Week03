  groups:
  - emotion: -1
    lines:
    - text: "\uADF8 \uAE30\uC5B5\uC774... \uC544\uC9C1\uB3C4 \uB0A8\uC544\uC788\uC5B4\uC694.
        \uC65C\uC778\uC9C0\uB294 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uADF8\uB0E5 \uB9C8\uC74C\uC18D\uC5D0
        \uBC15\uD600\uC788\uC5B4\uC694."
      minAge: -1
      maxAge: -1
    - text: "\uBCC4\uB85C \uD2B9\uBCC4\uD55C \uB0A0\uC774 \uC544\uB2C8\uC5C8\uB294\uB370,
        \uADF8\uB54C\uAC00 \uC790\uAFB8 \uB5A0\uC62C\uB77C\uC694. \uAE30\uC5B5\uC774\uB780
        \uAC8C \uCC38 \uC774\uC0C1\uD558\uC8E0."
      minAge: -1
      maxAge: -1
    - text: "...\uADF8\uB0E5 \uD3C9\uBC94\uD588\uC5B4\uC694. \uADF8\uAC8C \uB2E4\uC608\uC694."
      minAge: -1
      maxAge: -1
  - emotion: 0
    lines:
    - text: "\uADF8\uB54C \uCC98\uC74C\uC73C\uB85C \uC9C4\uC9DC \uD654\uB97C \uB0C8\uC5B4\uC694.
        \uB108\uBB34 \uBD88\uACF5\uD3C9\uD558\uB2E4\uACE0 \uC0DD\uAC01\uD588\uAC70\uB4E0\uC694.
        \uC5B4\uB9B0 \uB9C8\uC74C\uC5D0 \uC628 \uC138\uC0C1\uC774 \uB098\uB9CC \uBBF8\uC6CC\uD558\uB294
        \uAC83 \uAC19\uC558\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uCE5C\uAD6C\uAC00 \uB0B4 \uAC78 \uB9DD\uAC00\uB728\uB824 \uB193\uACE0
        \uBAA8\uB978 \uCC99\uD588\uC5B4\uC694. \uADF8\uAC8C \uB108\uBB34 \uD654\uB0AC\uB294\uB370
        \uC544\uBB34\uB3C4 \uD3B8\uC744 \uC548 \uB4E4\uC5B4\uC92C\uC5B4\uC694. \uC5B5\uC6B8\uD574\uC11C
        \uD63C\uC790 \uC6B8\uC5C8\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uC120\uC0DD\uB2D8\uD55C\uD14C \uD63C\uB0AC\uC744 \uB54C \uC5B5\uC6B8\uD588\uC5B4\uC694.
        \uB0B4\uAC00 \uD55C \uAC8C \uC544\uB2CC\uB370. \uADF8\uB54C\uBD80\uD130 \uBB54\uAC00
        \uC5B4\uB978\uB4E4\uC744 \uC27D\uAC8C \uBBFF\uC9C0 \uC54A\uAC8C \uB41C \uAC83
        \uAC19\uC544\uC694."
      minAge: 11
      maxAge: 14
    - text: "\uCE5C\uAD6C\uB4E4 \uC55E\uC5D0\uC11C \uB9DD\uC2E0\uB2F9\uD55C \uAE30\uC5B5\uC774\uC5D0\uC694.
        \uC6C3\uC74C\uAC70\uB9AC\uAC00 \uB410\uB294\uB370 \uC544\uBB34\uB3C4 \uB9D0\uB824\uC8FC\uC9C0
        \uC54A\uC558\uC5B4\uC694. \uADF8\uB54C\uC758 \uBD84\uD568\uC774 \uC9C0\uAE08\uB3C4
        \uC0DD\uC0DD\uD574\uC694."
      minAge: 11
      maxAge: 14
    - text: "\uC5F4\uC2EC\uD788 \uD588\uB294\uB370 \uACB0\uACFC\uAC00 \uC548 \uB098\uC654\uC744
        \uB54C\uC694. \uC544\uBB34\uB3C4 \uB178\uB825\uC744 \uC778\uC815 \uC548 \uD574\uC92C\uC5B4\uC694.
        \uADF8 \uD654\uAC00 \uC5B4\uB514\uB85C \uAC00\uC57C \uD560\uC9C0\uB97C \uBAB0\uB790\uC5B4\uC694."
      minAge: 15
      maxAge: 20
    - text: "\uCC98\uC74C\uC73C\uB85C '\uC774\uAC74 \uC544\uB2C8\uB2E4' \uC2F6\uC5B4\uC11C
        \uB9DE\uC130\uC5B4\uC694. \uACB0\uACFC\uB294 \uC88B\uC9C0 \uC54A\uC558\uC9C0\uB9CC,
        \uADF8\uB798\uB3C4 \uADF8\uB54C \uB9D0\uC744 \uD574\uC11C \uB2E4\uD589\uC774\uB77C\uACE0
        \uC0DD\uAC01\uD574\uC694."
      minAge: 15
      maxAge: 20
  - emotion: 2
    lines:
    - text: "\uCE5C\uD55C \uCE5C\uAD6C\uAC00 \uC774\uC0AC\uB97C \uAC00\uB358 \uB0A0\uC774\uC5D0\uC694.
        \uC5F0\uB77D\uD558\uC790\uACE0 \uD588\uB294\uB370, \uC810\uC810 \uBA40\uC5B4\uC9C0\uB354\uB77C\uACE0\uC694.
        \uADF8\uAC8C \uC774\uBCC4\uC774\uB77C\uB294 \uAC78 \uADF8\uB54C \uCC98\uC74C
        \uC54C\uC558\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uC6B4\uB3D9\uD68C \uB0A0 \uC544\uBB34\uB3C4 \uAC19\uC774 \uB6F0\uC5B4\uC8FC\uC9C0
        \uC54A\uC558\uC5B4\uC694. \uC0AC\uB78C\uB4E4\uC774 \uB9CE\uC740\uB370 \uD63C\uC790\uC778
        \uB290\uB08C. \uADF8 \uC6B4\uB3D9\uC7A5\uC774 \uC5C4\uCCAD \uB113\uAC8C \uB290\uAEF4\uC84C\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uADF8 \uC2DC\uAE30\uC5D0\uB294 \uAD50\uC2E4\uC5D0\uC11C\uB3C4 \uD63C\uC790\uC778
        \uAC83 \uAC19\uC558\uC5B4\uC694. \uBB34\uB9AC\uC5D0 \uB084 \uC218\uAC00 \uC5C6\uC5C8\uAC70\uB4E0\uC694.
        \uC810\uC2EC\uC744 \uC5B4\uB514\uC11C \uBA39\uC5B4\uC57C \uD558\uB098 \uACE0\uBBFC\uD558\uB358
        \uAC8C \uC544\uC9C1\uB3C4 \uAE30\uC5B5\uB098\uC694."
      minAge: 11
      maxAge: 14
    - text: "\uC544\uBB34\uD55C\uD14C\uB3C4 \uD558\uC9C0 \uBABB\uD55C \uACE0\uBBFC\uC774
        \uC788\uC5C8\uC5B4\uC694. \uB9D0\uD558\uBA74 \uC774\uC0C1\uD558\uAC8C \uBCFC
        \uAC83 \uAC19\uC544\uC11C\uC694. \uD63C\uC790 \uC0BC\uCF1C\uC57C \uD588\uB358
        \uADF8 \uAE30\uC5B5\uC774 \uC81C\uC77C \uC678\uB85C\uC6CC\uC694."
      minAge: 11
      maxAge: 14
    - text: "\uCE5C\uD588\uB358 \uCE5C\uAD6C\uB791 \uBA40\uC5B4\uC84C\uC5B4\uC694.
        \uB531\uD788 \uC2F8\uC6B4 \uAC83\uB3C4 \uC544\uB2CC\uB370, \uC5B4\uB290 \uC21C\uAC04
        \uC11C\uB85C \uB2E4\uB978 \uBC29\uD5A5\uC744 \uBCF4\uACE0 \uC788\uC5C8\uC5B4\uC694.
        \uADF8\uAC8C \uB354 \uC501\uC4F8\uD588\uC5B4\uC694."
      minAge: 15
      maxAge: 20
    - text: "\uADF8\uB54C \uCC98\uC74C\uC73C\uB85C '\uC544, \uB098\uB294 \uD63C\uC790\uAD6C\uB098'
        \uC2F6\uC740 \uAC8C \uC2E4\uAC10 \uB0AC\uC5B4\uC694. \uC0AC\uB78C\uC774 \uB9CE\uC544\uB3C4
        \uC9C4\uC9DC \uB098\uB97C \uC544\uB294 \uC0AC\uB78C\uC774 \uC5C6\uB294 \uAC83
        \uAC19\uC544\uC11C\uC694."
      minAge: 15
      maxAge: 20
  - emotion: 1
    lines:
    - text: "\uBE44 \uC624\uB294 \uB0A0 \uCC98\uB9C8 \uBC11\uC5D0\uC11C \uBE57\uC18C\uB9AC
        \uB4E3\uB358 \uAE30\uC5B5\uC774\uC5D0\uC694. \uC544\uBB34\uAC83\uB3C4 \uC548
        \uD558\uACE0 \uADF8\uB0E5 \uC549\uC544 \uC788\uC5C8\uB294\uB370, \uADF8\uAC8C
        \uC88B\uC558\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uAC15\uC544\uC9C0\uB791 \uB204\uC6CC\uC788\uB358 \uC624\uD6C4\uC608\uC694.
        \uB530\uB73B\uD558\uACE0 \uC544\uBB34 \uAC71\uC815\uC774 \uC5C6\uC5C8\uC5B4\uC694.
        \uADF8 \uC21C\uAC04\uC774 \uC9C0\uAE08 \uC0DD\uAC01\uD574\uB3C4 \uD3B8\uC548\uD574\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uC88B\uC544\uD558\uB294 \uAC78 \uCC3E\uC558\uC744 \uB54C\uC694. \uCC45\uC774\uB4E0
        \uADF8\uB9BC\uC774\uB4E0 \uBB54\uAC00 \uD558\uB098 \uBE60\uC838\uB4E4\uAC8C
        \uB418\uBA74 \uC2DC\uAC04\uC774 \uC5B4\uB5BB\uAC8C \uC9C0\uB098\uB294\uC9C0
        \uBAB0\uB790\uC5B4\uC694. \uADF8\uAC8C \uC81C\uC77C \uD3B8\uD55C \uC2DC\uAC04\uC774\uC5C8\uC5B4\uC694."
      minAge: 11
      maxAge: 14
    - text: "\uD63C\uC790 \uC0B0\uCC45\uD558\uB358 \uB0A0\uC774\uC5D0\uC694. \uC544\uBB34
        \uC0DD\uAC01 \uC5C6\uC774 \uADF8\uB0E5 \uAC78\uC5C8\uB294\uB370, \uC774\uC0C1\uD558\uAC8C
        \uBA38\uB9AC\uAC00 \uB9D1\uC544\uC84C\uC5B4\uC694. \uADF8\uB54C\uBD80\uD130
        \uD63C\uC790\uB9CC\uC758 \uC2DC\uAC04\uC774 \uD544\uC694\uD558\uB2E4\uB294
        \uAC78 \uC54C\uC558\uC5B4\uC694."
      minAge: 11
      maxAge: 14
    - text: "\uACB0\uACFC\uC5D0 \uC9D1\uCC29 \uC548 \uD558\uACE0 \uADF8\uB0E5 \uD55C
        \uC801\uC774 \uC788\uC5B4\uC694. \uADF8\uB7F0\uB370 \uADF8\uAC8C \uC81C\uC77C
        \uC798 \uB410\uC5B4\uC694. \uD798\uC744 \uBE80\uB2E4\uB294 \uAC8C \uADF8\uB7F0
        \uAC74\uAC00 \uC2F6\uC5C8\uC8E0."
      minAge: 15
      maxAge: 20
    - text: "\uC870\uC6A9\uD788 \uC549\uC544\uC11C \uC88B\uC544\uD558\uB294 \uC74C\uC545
        \uB4E3\uB358 \uBC24\uC774\uC5D0\uC694. \uC544\uBB34\uB3C4 \uC5C6\uACE0 \uC544\uBB34\uAC83\uB3C4
        \uC548 \uD574\uB3C4 \uB418\uB294 \uC2DC\uAC04. \uADF8\uB54C\uAC00 \uC81C\uC77C
        \uB098\uB2E4\uC6E0\uB358 \uAC83 \uAC19\uC544\uC694."
      minAge: 15
      maxAge: 20
  - emotion: 3
    lines:
    - text: "\uADF8\uB0A0\uC774 \uC81C\uC77C \uC2E0\uB0AC\uC5B4\uC694. \uCE5C\uAD6C\uB4E4\uC774\uB791
        \uC885\uC77C \uB6F0\uC5B4\uB180\uACE0, \uBC25\uB3C4 \uAC19\uC774 \uBA39\uACE0.
        \uD574\uAC00 \uC9C0\uB294 \uAC83\uB3C4 \uBAB0\uB790\uC5B4\uC694. \uADF8\uB54C\uAC00
        \uC81C\uC77C \uC88B\uC558\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uC0DD\uC77C\uC5D0 \uCF00\uC774\uD06C \uCD08\uB97C \uB044\uB358 \uB0A0\uC774\uC5D0\uC694.
        \uC18C\uC6D0\uC744 \uC5C4\uCCAD \uC5F4\uC2EC\uD788 \uBE4C\uC5C8\uB294\uB370
        \uBB58 \uBE4C\uC5C8\uB294\uC9C0\uB294 \uAE30\uC5B5 \uC548 \uB098\uC694. \uADF8\uB0E5
        \uC124\uB808\uC5C8\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uCC98\uC74C\uC73C\uB85C \uBB54\uAC00\uB97C \uC798\uD574\uB0C8\uB2E4\uB294
        \uB9D0\uC744 \uB4E4\uC5C8\uC744 \uB54C\uC694. \uADF8 \uCE6D\uCC2C \uD558\uB098\uB85C
        \uC77C\uC8FC\uC77C\uC774 \uAE30\uBD84 \uC88B\uC558\uC5B4\uC694. \uC544\uC9C1\uB3C4
        \uADF8 \uB290\uB08C\uC774 \uAE30\uC5B5\uB098\uC694."
      minAge: 11
      maxAge: 14
    - text: "\uC218\uD559\uC5EC\uD589\uC774 \uC815\uB9D0 \uC88B\uC558\uC5B4\uC694.
        \uCE5C\uAD6C\uB4E4\uC774\uB791 \uBC24\uC0C8 \uC598\uAE30\uD558\uACE0, \uADDC\uCE59\uB3C4
        \uC870\uAE08\uC529 \uC5B4\uAE30\uACE0. \uADF8\uB54C \uC6C3\uC74C\uC774 \uC9C0\uAE08\uB3C4
        \uB5A0\uC62C\uB77C\uC694."
      minAge: 11
      maxAge: 14
    - text: "\uC2DC\uD5D8 \uB05D\uB098\uACE0 \uCE5C\uAD6C\uB4E4\uC774\uB791 \uBA39\uC5C8\uB358
        \uB5A1\uBCF6\uC774\uC608\uC694. \uC544\uBB34\uAC83\uB3C4 \uC548 \uC911\uC694\uD558\uACE0,
        \uADF8\uB0E5 \uAC19\uC774 \uC788\uB294 \uAC8C \uC88B\uC558\uC5B4\uC694. \uC18C\uC18C\uD588\uB294\uB370
        \uC815\uB9D0 \uD589\uBCF5\uD588\uC5B4\uC694."
      minAge: 15
      maxAge: 20
    - text: "\uBB54\uAC00\uB97C \uD574\uB0C8\uC744 \uB54C\uC694. \uC624\uB798 \uC5F0\uC2B5\uD588\uB294\uB370
        \uB4DC\uB514\uC5B4 \uB410\uC744 \uB54C\uC758 \uADF8 \uAE30\uBD84. \uB0A8\uD55C\uD14C
        \uBCF4\uC5EC\uC8FC\uACE0 \uC2F6\uC5B4\uC11C \uC5B4\uCA54 \uC904 \uBAB0\uB790\uC5B4\uC694."
      minAge: 15
      maxAge: 20
  - emotion: 4
    lines:
    - text: "\uC0C8 \uD559\uB144\uC774 \uC2DC\uC791\uB418\uB358 \uB0A0\uC774\uC5D0\uC694.
        \uC0C8 \uAD50\uACFC\uC11C \uB0C4\uC0C8\uB791 \uC0C8 \uCE5C\uAD6C\uB4E4. \uC5B4\uB5BB\uAC8C
        \uB420\uC9C0 \uBAB0\uB77C\uC11C \uB450\uADFC\uB450\uADFC\uD588\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uCC98\uC74C \uAC00\uBCF4\uB294 \uACF3\uC5D0 \uAC14\uC744 \uB54C\uC608\uC694.
        \uBB50\uAC00 \uC788\uC744\uC9C0 \uBAA8\uB974\uB294\uB370 \uC790\uAFB8 \uC55E\uC73C\uB85C
        \uAC77\uACE0 \uC2F6\uC5C8\uC5B4\uC694. \uADF8 \uC124\uB808\uB294 \uB290\uB08C\uC774
        \uC88B\uC558\uC5B4\uC694."
      minAge: 5
      maxAge: 10
    - text: "\uC88B\uC544\uD558\uB294 \uC0AC\uB78C\uC774 \uC0DD\uACBC\uC744 \uB54C\uC694.
        \uB9D0 \uD55C\uB9C8\uB514\uC5D0 \uD558\uB8E8 \uC885\uC77C \uC758\uBBF8\uB97C
        \uCC3E\uACE0, \uC2EC\uC7A5\uC774 \uBE68\uB9AC \uB6F0\uACE0. \uADF8 \uB290\uB08C\uC774
        \uC774\uC0C1\uD558\uBA74\uC11C\uB3C4 \uC88B\uC558\uC5B4\uC694."
      minAge: 13
      maxAge: 17
    - text: "\uACE0\uB4F1\uD559\uAD50 \uCC98\uC74C \uB4E4\uC5B4\uAC00\uB358 \uB0A0\uC774\uC5D0\uC694.
        \uB2E4 \uB0AF\uC120\uB370 \uC774\uC0C1\uD558\uAC8C \uAE30\uB300\uB410\uC5B4\uC694.
        \uC55E\uC73C\uB85C \uBB54\uAC00 \uB2EC\uB77C\uC9C8 \uAC83 \uAC19\uC740 \uC608\uAC10
        \uAC19\uC740 \uAC8C \uC788\uC5C8\uC5B4\uC694."
      minAge: 15
      maxAge: 16
    - text: "\uBB54\uAC00\uB97C \uCC98\uC74C \uC2DC\uC791\uD558\uB358 \uB0A0\uC774\uC5D0\uC694.
        \uC798 \uB420\uC9C0 \uBAA8\uB974\uACA0\uC9C0\uB9CC, \uD574\uBCF4\uACE0 \uC2F6\uB2E4\uB294
        \uAC8C \uB354 \uCEF8\uC5B4\uC694. \uADF8 \uB450\uADFC\uAC70\uB9BC\uC774 \uC544\uC9C1\uB3C4
        \uC0DD\uC0DD\uD574\uC694."
      minAge: 15
      maxAge: 20
  - emotion: 5
    lines:
    - text: "\uBC1C\uD45C \uC804\uB0A0 \uBC24\uC5D0 \uC7A0\uC744 \uBABB \uC7A4\uC5B4\uC694.
        \uD2C0\uB9AC\uBA74 \uC5B4\uCA4C\uC9C0, \uCE5C\uAD6C\uB4E4\uC774 \uC6C3\uC73C\uBA74
        \uC5B4\uCA4C\uC9C0. \uBCC4\uBCC4 \uC0DD\uAC01\uC774 \uB2E4 \uB4E4\uC5C8\uC5B4\uC694."
      minAge: 8
      maxAge: 13
    - text: "\uC2DC\uD5D8 \uACB0\uACFC\uAC00 \uB098\uC624\uB294 \uB0A0\uC774\uBA74
        \uD56D\uC0C1 \uC2EC\uC7A5\uC774 \uCFF5\uCF85\uAC70\uB838\uC5B4\uC694. \uC798
        \uBD24\uC5B4\uB3C4 \uBD88\uC548\uD558\uACE0, \uBABB \uBD24\uC744 \uAC83 \uAC19\uC73C\uBA74
        \uB354 \uBD88\uC548\uD558\uACE0."
      minAge: 11
      maxAge: 14
    - text: "\uADF8 \uC2DC\uAE30\uB294 \uC9C4\uC9DC \uBD88\uC548\uD588\uC5B4\uC694.
        \uB0B4\uAC00 \uC5B4\uB5BB\uAC8C \uBCF4\uC77C\uC9C0, \uB9D0\uC774 \uC774\uC0C1\uD558\uC9C0
        \uC54A\uC740\uC9C0, \uACC4\uC18D \uC2E0\uACBD\uC774 \uC4F0\uC600\uC5B4\uC694.
        \uC790\uC5F0\uC2A4\uB7FD\uAC8C \uC788\uB294 \uAC8C \uC81C\uC77C \uC5B4\uB824\uC6E0\uC5B4\uC694."
      minAge: 13
      maxAge: 17
    - text: "\uC218\uB2A5\uC774 \uAC00\uAE4C\uC6CC\uC9C0\uB358 \uB54C\uC694. \uC5F4\uC2EC\uD788
        \uD588\uB294\uB370\uB3C4 \uC790\uAFB8 \uBD80\uC871\uD55C \uAC83 \uAC19\uC740
        \uB290\uB08C\uC774 \uB4E4\uC5C8\uC5B4\uC694. \uADF8 \uBD88\uC548\uAC10\uC740
        \uC9C0\uAE08\uB3C4 \uAFC8\uC5D0 \uB098\uC640\uC694."
      minAge: 17
      maxAge: 20
    - text: "\uC55E\uC73C\uB85C \uC5B4\uB5BB\uAC8C \uD574\uC57C \uD560\uC9C0 \uBAA8\uB974\uACA0\uB294
        \uC2DC\uAC04\uC774 \uC788\uC5C8\uC5B4\uC694. \uB2E4\uB4E4 \uBB54\uAC00\uB97C
        \uD5A5\uD574 \uAC00\uB294 \uAC83 \uAC19\uC740\uB370, \uB098\uB9CC \uBA48\uCDB0\uC788\uB294
        \uAC83 \uAC19\uC544\uC11C\uC694."
      minAge: 18
      maxAge: 20
  - emotion: 6
    lines:
    - text: "\uC544\uBB34\uAC83\uB3C4 \uD558\uAE30 \uC2EB\uC5C8\uC5B4\uC694. \uC774\uC720\uB3C4
        \uC5C6\uC774\uC694. \uADF8\uB0E5 \uB2E4 \uBB34\uC758\uBBF8\uD55C \uAC83 \uAC19\uC558\uC5B4\uC694."
      minAge: -1
      maxAge: -1
    - text: "\uADF8\uB54C \uC544\uBB34\uB7F0 \uAC10\uC815\uC774 \uC5C6\uC5C8\uC5B4\uC694.
        \uC2AC\uD504\uC9C0\uB3C4 \uAE30\uC058\uC9C0\uB3C4 \uC54A\uACE0. \uADF8\uB0E5
        \uD145 \uBE48 \uAC83 \uAC19\uC740 \uB290\uB08C\uC774\uC5C8\uC5B4\uC694."
      minAge: 13
      maxAge: 20
    - text: "\uC5F4\uC2EC\uD788 \uD588\uB294\uB370 \uBB54\uAC00 \uB0A8\uC740 \uAC8C
        \uC5C6\uB294 \uAC83 \uAC19\uC558\uC5B4\uC694. \uC758\uBBF8\uAC00 \uC788\uC5C8\uACA0\uC8E0?
        \uADF8\uB807\uAC8C \uBBFF\uACE0 \uC2F6\uC5B4\uC694."
      minAge: 16
      maxAge: 20
  - emotion: 7
    lines:
    - text: "\uC544\uC9C1\uB3C4 \uADF8\uAC8C \uB5A0\uC62C\uB77C\uC694. \uC5ED\uACA8\uC6E0\uAC70\uB4E0\uC694.
        \uC65C \uC0AC\uB78C\uC774 \uADF8\uB7F4 \uC218 \uC788\uB294\uC9C0, \uC73C\uC74F....
        \uD1A0 \uB098\uC624\uB124\uC694."
      minAge: -1
      maxAge: -1
    - text: "\uCC98\uC74C\uBD80\uD130 \uC5ED\uACA8\uC6E0\uC5B4\uC694. \uBAB8\uC5D0\uC11C\uB294
        \uC774\uC0C1\uD55C \uB0C4\uC0C8\uAC00 \uB098\uC9C0 \uC5BC\uAD74\uB3C4 \uAE30\uAD34\uD558\uAC8C
        \uC0DD\uACBC\uC9C0, \uAC00\uAE4C\uC774\uD558\uACE0 \uC2F6\uC9C0 \uC54A\uC558\uB294\uB370,
        \uC9C4\uC791 \uAC70\uB9AC\uB97C \uB46C\uC57C\uD588\uC5B4\uC694."
      minAge: -1
      maxAge: -1
    - text: "\uADF8 \uC790\uB9AC\uC5D0 \uC788\uC5C8\uB358 \uAC8C \uD6C4\uD68C\uB3FC\uC694.
        \uB108\uBB34 \uB054\uCC0D\uD55C\uAC78 \uBAA9\uACA9\uD588\uAC70\uB4E0\uC694.
        \uC544\uBB34\uB9AC \uC78A\uC73C\uB824 \uD574\uB3C4 \uC78A\uC5B4\uC9C0\uC9C0\uAC00
        \uC54A\uC544\uC694."
      minAge: -1
      maxAge: -1
    - text: "\uADF8 \uB208\uBE5B\uC774 \uC2EB\uC5C8\uC5B4\uC694. \uD56D\uC0C1 \uBB54\uAC00\uB97C
        \uACC4\uC0B0\uD558\uB294 \uAC83 \uAC19\uC740 \uB208\uC774\uC694. \uC6C3\uC744
        \uB54C\uB9C8\uB2E4 \uC18C\uB984\uC774 \uB3CB\uC558\uC5B4\uC694. \uADF8\uB7F0
        \uC0AC\uB78C\uC778 \uC904 \uC54C\uC558\uC5B4\uC694, \uCC98\uC74C\uBD80\uD130."
      minAge: -1
      maxAge: -1
    - text: "\uC65C \uB098\uB9CC \uADF8 \uC0AC\uB78C\uC774 \uC774\uC0C1\uD558\uB2E4\uB294
        \uAC78 \uC54C\uC558\uC744\uAE4C\uC694. \uB2E4\uB4E4 \uC88B\uB2E4\uACE0 \uD588\uB294\uB370.
        \uB0B4\uAC00 \uD2C0\uB9B0 \uAC74\uC9C0, \uB098\uB9CC \uC9C4\uC2E4\uC744 \uBCF8
        \uAC74\uC9C0. \uC9C0\uAE08\uB3C4 \uBAA8\uB974\uACA0\uC5B4\uC694."
      minAge: -1
      maxAge: -1
    - text: "\uADF8 \uC0AC\uB78C \uC0DD\uAC01\uB9CC \uD558\uBA74 \uBAB8\uC774 \uAD73\uC5B4\uC694.
        \uAC19\uC740 \uACF5\uAC04\uC5D0 \uC788\uC5C8\uB2E4\uB294 \uAC83\uB9CC\uC73C\uB85C\uB3C4
        \uB354\uB7EC\uC6B4 \uAC83 \uAC19\uC544\uC11C \uC9D1\uC5D0 \uC640\uC11C \uC53B\uC5C8\uC5B4\uC694.
        \uADF8 \uAE30\uC5B5\uC740 \uC544\uBB34\uB9AC \uC53B\uC5B4\uB3C4 \uC548 \uC9C0\uC6CC\uC9C0\uB354\uB77C\uACE0\uC694."
      minAge: -1
      maxAge: -1
  - emotion: 8
    lines:
    - text: "\uC5EC\uC804\uD788 \uBB34\uC11C\uC6CC\uC694. \uB192\uC740 \uACF3\uC5D0\uC11C
