  m_Script: {fileID: 11500000, guid: b5e65e0a3000a794a99ba738f5dcaad4, type: 3}
  m_Name: IntroConversation
  m_EditorClassIdentifier: Assembly-CSharp::StoryGraph
  StartNodeId: start
  Nodes:
  - Id: start
    Lines:
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uC548\uB155\uD558\uC138\uC694...?"
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uC5B4\uC11C\uC624\uC138\uC694. \uAE40\uC138\uB77C\uC528 \uB9DE\uB098\uC694?"
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uB124..."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uB108\uBB34 \uAE34\uC7A5\uD558\uC9C0 \uB9C8\uC138\uC694, 30\uBD84\uC774\uBA74
        \uAE08\uBC29 \uB05D\uB0A9\uB2C8\uB2E4."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uC800\uB294 \uC5EC\uAE30\uC11C \uBB58 \uD558\uB294 \uAC74\uAC00\uC694?"
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uAC04\uB2E8\uD55C \uC2EC\uB9AC \uCE58\uB8CC\uC785\uB2C8\uB2E4."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uCD5C\uADFC\uC5D0 \uAC10\uC815\uC774 \uCEE8\uD2B8\uB864\uC774 \uC798
        \uC548\uB41C\uB2E4\uAC70\uB098, \uACFC\uAC70\uAC00 \uC798 \uAE30\uC5B5\uC774
        \uC548\uB098\uC2DC\uC8E0?"
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uB124... \uCD5C\uADFC \uB4E4\uC5B4 \uC2EC\uD574\uC9C0\uAE30 \uC2DC\uC791\uD588\uC5B4\uC694."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uADF8\uAC78 \uCE58\uB8CC\uD558\uAE30 \uC704\uD574\uC11C"
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "<size=120><color=red><b>\uCD5C\uBA74</b></color></size>\uC744 \uD1B5\uD574
        \uD2B8\uB79C\uC2A4 \uC0C1\uD0DC\uB85C \uB118\uC5B4\uAC00\uC11C \uC138\uB77C\uC591\uC758
        \uAE30\uC5B5\uC744 \uB418\uC0B4\uB9B4\uAC81\uB2C8\uB2E4."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "<size=150><color=red><b>\uCD5C\uBA74\uC774\uC694?!?! </b></color></size>\n\uC81C\uAC00
        \uCD5C\uBA74\uC0C1\uD0DC\uAC00 \uB41C \uC0AC\uC774\uC5D0 \uB098\uC05C \uC9D3\uD558\uC2DC\uAC70\uB098
        \uADF8\uB7F4 \uC0DD\uAC01\uC774\uC2E0\uAC70\uC8E0!?"
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uC0C1\uC0C1\uB825\uC774 \uD48D\uBD80\uD558\uC2DC\uB124\uC694. "
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uADF8\uB7F0\uAC8C \uAC00\uB2A5\uD558\uB2E4\uBA74 \uC804 \uC774\uBBF8
        \uC740\uD589\uC744 \uD138\uACE0 \uD558\uC640\uC774\uC5D0 \uAC00\uC788\uC9C0
        \uC54A\uC744\uAE4C\uC694?"
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uC544... \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uC88B\uC2B5\uB2C8\uB2E4. \uC138\uB77C\uC591\uC774 \uC5B4\uB5A4 \uBD84\uC778\uC9C0
        \uB354 \uC798 \uC54C\uAC83 \uAC19\uB124\uC694."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uADF8\uB7EC\uBA74 \uCE58\uB8CC\uB97C \uC704\uD574, \uB208\uC744 \uAC10\uC73C\uC2E0
        \uD6C4 \uD55C\uBC88 \uC61B\uB0A0 \uCD94\uC5B5\uC744 \uB5A0\uC62C\uB824 \uBCF4\uC2DC\uACA0\uC5B4\uC694?"
    - SpeakerName: 
      Text: "\uAE40\uC138\uB77C\uB294 \uCC9C\uCC9C\uD788 \uB208\uC744 \uAC10\uAE30
        \uC2DC\uC791\uD55C\uB2E4."
    NextNodeId: 
    LoadScene: TutorialScene
