  Nodes:
  - Id: end
    Lines:
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: ...
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uADF8\uB798\uC694. \uB0B4\uAC00 \uC8FD\uC600\uC5B4\uC694."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uACE0\uC758\uB294 \uC544\uB2C8\uC600\uC5B4\uC694."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uADF8\uC800... \uC704\uD611\uB9CC \uD558\uB824\uACE0 \uD55C\uAC70\uC600\uB294\uB370..."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uADF8\uB300\uB85C \uC8FD\uC5B4\uBC84\uB838\uC8E0."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uB2E4\uD589\uD788 \uBAA9\uACA9\uD55C \uC0AC\uB78C\uC740 \uC5C6\uC5C8\uACE0,
        \uC218\uC0AC\uB3C4 \uC774\uC0C1\uD55C \uBC29\uD5A5\uC73C\uB85C \uAC00\uC11C
        \uB2E4\uB978 \uC0AC\uB78C\uC774 \uBC94\uC778\uC73C\uB85C \uC7A1\uD788\uAC8C
        \uB418\uC5C8\uC5B4\uC694."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uD760... \uC815\uB9D0\uC694?"
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uB124? \uADF8\uAC8C \uBB34\uC2A8..."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uC815\uB9D0 \uAE30\uC5B5\uB098\uC9C0 \uC54A\uC73C\uC2E0\uAC00\uC694?\n\uC9C0\uAE08
        \uC0C1\uB2F4 \uBC1B\uC73C\uB7EC \uC624\uC2E0 \uC774\uC720\uAC00 \uBB50\uC8E0?"
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uADF8\uC57C..... \uC7AC\uD310 \uB54C\uBB38\uC5D0... <size=120><color=red><b>\uC5B4?</b></color></size>"
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uC2EC\uC2E0\uBBF8\uC57D \uC0C1\uD0DC\uAC00 \uD574\uACB0\uB418\uC5C8\uC73C\uB2C8,
        \uC774\uC81C \uC815\uC2DD\uC73C\uB85C \uC7AC\uD310\uBC1B\uC73C\uC2DC\uBA74
        \uB429\uB2C8\uB2E4."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uC218\uACE0\uD558\uC168\uC2B5\uB2C8\uB2E4."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uC544\uBB34\uB9AC \uC81C \uB3D9\uC0DD\uC774 \uAD34\uC0C1\uD558\uAC8C
        \uC0DD\uAE30\uAE34 \uD588\uC5B4\uB3C4, \uB204\uAD74 \uC8FD\uC774\uAE30\uC5D4
        \uB108\uBB34 \uCC29\uD55C \uC544\uC774\uB77C\uC11C\uC694."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uC544... \uC124\uB9C8..."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uADF8\uB807\uC2B5\uB2C8\uB2E4. \uC774\uC81C\uC57C \uC138\uB77C\uC591\uC774
        \uC5B4\uB5A4 \uBD84\uC778\uC9C0 \uB354 \uC798 \uC54C\uAC83 \uAC19\uB124\uC694."
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uADF8\uB7EC\uBA74 \uC774\uC81C \uB098\uAC00\uC8FC\uC2DC\uACA0\uC5B4\uC694?"
    - SpeakerName: "\uB2F9\uC2E0(\uC2EC\uB9AC\uC0C1\uB2F4\uAC00)"
      Text: "\uAC19\uC740 \uACF5\uAC04\uC5D0 \uC788\uB294\uAC83\uB9CC\uC73C\uB85C\uB3C4
        \uBD88\uCF8C\uD558\uB124\uC694."
    - SpeakerName: 
      Text: "\uAE40\uC138\uB77C\uB294 \uC2DC\uCCB4\uCC98\uB7FC \uB4A4\uB85C \uC4F0\uB7EC\uC9C4\uB2E4."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "\uC73D..."
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "(\uBA38\uB9AC\uB97C \uBC14\uB2E5\uC5D0 \uBC15\uC790 \uD1B5\uC99D\uC774
        \uBAB0\uB824\uC654\uB2E4.)\n"
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "(\uB3D9\uC2DC\uC5D0 \uD604\uC2E4\uC744 \uAE68\uB2EB\uAC8C\uB418\uBA74\uC11C
        \uC228\uC774 \uB9C9\uD600\uC628\uB2E4.) "
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "<color=red><b>\uAD1C\uCC2E\uC544....</b></color>"
    - SpeakerName: "\uAE40\uC138\uB77C(21, \uB0B4\uB2F4\uC790)"
      Text: "<size=170><color=red><b>\uBAA8\uB4E0\uAC8C \uB2E4 \uAD1C\uCC2E\uC544\uC9C8\uAC70\uC57C....</b></color></size>"
    - SpeakerName: "\uD074\uB9AC\uC5B4!"
      Text: "\uAC8C\uC784 \uD074\uB9AC\uC5B4\uB97C \uCD95\uD558\uD574! \n\uC6D0\uB798
        \uC5EC\uAE30 \uC801\uC744 \uC0DD\uAC01\uC740 \uC544\uB2C8\uC600\uB294\uB370....
        \uC9C0\uAE08\uC774 \uC0C8\uBCBD 6\uC2DC\uB77C. "
    - SpeakerName: "\uD074\uB9AC\uC5B4!"
      Text: "\uC544\uBB34\uD2BC \uAC8C\uC784\uC744 \uD50C\uB808\uC774\uD574\uC918\uC11C
        \uACE0\uB9C8\uC6CC"
    - SpeakerName: "\uD074\uB9AC\uC5B4!"
      Text: "\uB300\uCDA9 \uC0C1\uB2F4\uD558\uB294 \uCEE8\uC149\uC758 \uAC8C\uC784\uC774\uC600\uACE0,
        \uBB50 \uC0B4\uC778\uD604\uC7A5\uC744 \uBAA9\uACA9\uD55C\uC904 \uC54C\uC558\uC9C0\uB9CC
        \uC0AC\uC2E4\uC740 \uBCF8\uC778\uC774 \uC8FD\uC600\uB2E4 \uBB50 \uC774\uB7F0
        \uB0B4\uC6A9\uC774\uC57C."
    - SpeakerName: "\uD074\uB9AC\uC5B4!"
      Text: "\uC2A4\uD1A0\uB9AC\uB294 \uCC98\uC74C \uB123\uC5B4\uBD10\uC11C \uB9CE\uC774
        \uC5B4\uC0C9\uD558\uB124"
    - SpeakerName: "\uD074\uB9AC\uC5B4!"
      Text: "\uC544\uBB34\uD2BC \uD50C\uB808\uC774\uD574\uC918\uC11C \uACE0\uB9C8\uC6CC"
    NextNodeId: 
